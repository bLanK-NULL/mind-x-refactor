{
  "name": "mind-x-refactor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "tsc -b packages/shared packages/mind-engine apps/api && npm run build -w apps/web",
    "typecheck": "tsc -b packages/shared packages/mind-engine apps/api && npm run typecheck -w apps/web",
    "test": "vitest run --exclude '.worktrees/**'",
    "test:engine": "npm run test -w packages/mind-engine",
    "test:api": "npm run test -w apps/api"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.6.3",
    "vitest": "^4.0.7"
  },
  "engines": {
    "node": ">=20"
  }
}
